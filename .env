# --- Required
GROQ_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=campaign-mgmt

# --- Database
# Local (SQLite - default, no setup needed)
DATABASE_URL=sqlite:///./campaign.db

# GCP Cloud Run (PostgreSQL via Cloud SQL - uncomment for GCP)
# DATABASE_URL=postgresql+pg8000://campaign:campaign@/campaign_db?unix_sock=/cloudsql/PROJECT:REGION:campaign-db/.s.PGSQL.5432

# --- Knowledge Base
CHROMA_PERSIST_DIR=./chroma_db

# --- Environment
# local | gcp
ENVIRONMENT=local